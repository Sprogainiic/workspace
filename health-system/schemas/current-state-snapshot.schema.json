{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CurrentStateSnapshot",
  "type": "object",
  "required": ["snapshot_id", "updated_at", "state", "risk_flags", "simplification_level", "active_modes", "open_ambiguities"],
  "properties": {
    "snapshot_id": {"type": "string"},
    "updated_at": {"type": "string"},
    "state": {
      "type": "object",
      "required": ["adherence", "fatigue", "motivation", "hunger", "training_load", "nutrition_consistency", "weight_trend", "behavior_state"],
      "properties": {
        "adherence": {"$ref": "#/$defs/stateField"},
        "fatigue": {"$ref": "#/$defs/stateField"},
        "motivation": {"$ref": "#/$defs/stateField"},
        "hunger": {"$ref": "#/$defs/stateField"},
        "training_load": {"$ref": "#/$defs/stateField"},
        "nutrition_consistency": {"$ref": "#/$defs/stateField"},
        "weight_trend": {"$ref": "#/$defs/stateField"},
        "behavior_state": {"$ref": "#/$defs/stateField"},
        "recent_misses": {"type": "integer", "minimum": 0},
        "streak_days": {"type": "integer", "minimum": 0},
        "last_training_event_at": {"type": ["string", "null"]},
        "last_meal_log_at": {"type": ["string", "null"]},
        "last_weight_at": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "risk_flags": {"type": "array", "items": {"type": "string"}},
    "simplification_level": {"type": "string", "enum": ["normal", "reduced", "stability"]},
    "active_modes": {"type": "array", "items": {"type": "string"}},
    "open_ambiguities": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "stateField": {
      "type": "object",
      "required": ["value", "confidence", "updated_at", "evidence_event_ids", "staleness"],
      "properties": {
        "value": {"type": ["string", "number", "boolean", "null"]},
        "confidence": {"type": "string", "enum": ["high", "medium", "low", "unsupported"]},
        "updated_at": {"type": "string"},
        "evidence_event_ids": {"type": "array", "items": {"type": "string"}},
        "staleness": {"type": "string", "enum": ["fresh", "aging", "stale"]}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
