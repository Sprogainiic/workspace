{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StructuredEvent",
  "type": "object",
  "required": ["event_id", "timestamp", "event_type", "source_message_id", "facts", "confidence", "write_scope"],
  "properties": {
    "event_id": {"type": "string"},
    "timestamp": {"type": "string"},
    "event_type": {"type": "string"},
    "source_message_id": {"type": "string"},
    "facts": {"type": "object"},
    "confidence": {"type": "string", "enum": ["high", "medium", "low", "unsupported"]},
    "ambiguities": {"type": "array", "items": {"type": "string"}},
    "write_scope": {"type": "string", "enum": ["canonical", "transient", "deferred", "rejected"]},
    "safe_to_write": {"type": "boolean"}
  },
  "additionalProperties": false
}
